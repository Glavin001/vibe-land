{
  "name": "vibe-land-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "gen:constants": "node ../scripts/gen-constants.mjs",
    "ensure:wasm-pack": "command -v wasm-pack >/dev/null 2>&1 || cargo install wasm-pack --locked",
    "build:wasm": "npm run gen:constants && wasm-pack build ../shared --target web --out-dir ../client/src/wasm/pkg",
    "dev": "vite",
    "dev:local-preview": "vite --mode local-preview",
    "build": "npm run build:wasm && tsc -b && vite build",
    "build:local-preview": "npm run build:wasm && tsc -b && vite build --mode local-preview",
    "build:vercel-local-preview": "rustup target add wasm32-unknown-unknown && npm run ensure:wasm-pack && npm run build:local-preview",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "simulate": "node --env-file=../.env --import=tsx/esm simulate.ts"
  },
  "dependencies": {
    "@react-three/drei": "^9.117.0",
    "@react-three/fiber": "^8.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.170.0",
    "@types/ws": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.2",
    "ws": "^8.0.0"
  }
}

# Rust game server
BIND_ADDR=0.0.0.0:4001
SKIP_SPACETIMEDB_VERIFY=1
SERVER_PORT=4001
SERVER_HOST=localhost

# Optional: point the client at a separate multiplayer backend origin.
# Leave unset when the web app and game server share the same origin.
# VITE_MULTIPLAYER_HTTP_ORIGIN=https://game.example.com

# WebTransport (QUIC/UDP)
WT_BIND_ADDR=0.0.0.0:4002
WT_HOST=127.0.0.1
# Optional override for the URL returned by /session-config.
# Use this when the public WebTransport endpoint differs from WT_BIND_ADDR,
# for example a DNS-only wt.example.com hostname or a forwarded public port.
# WT_PUBLIC_URL=https://wt.example.com:443
# Production: uncomment and point to your CA-signed cert files
# WT_CERT_PEM=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# WT_KEY_PEM=/etc/letsencrypt/live/yourdomain.com/privkey.pem

# Vite dev server
ALLOWED_HOSTS=localhost
CLIENT_PORT=5555

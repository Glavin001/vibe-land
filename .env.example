# Rust game server
BIND_ADDR=0.0.0.0:4001
SKIP_SPACETIMEDB_VERIFY=1
SERVER_PORT=4001
SERVER_HOST=localhost

# Optional: point the client at a separate multiplayer backend origin.
# Leave unset when the web app and game server share the same origin.
# VITE_MULTIPLAYER_HTTP_ORIGIN=https://game.example.com

# WebTransport (QUIC/UDP)
WT_BIND_ADDR=0.0.0.0:4002
WT_HOST=127.0.0.1
# Production: uncomment and point to your CA-signed cert files
# WT_CERT_PEM=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# WT_KEY_PEM=/etc/letsencrypt/live/yourdomain.com/privkey.pem

# Vite dev server
ALLOWED_HOSTS=localhost
CLIENT_PORT=5555

# Cloudflare R2 (optional — enables world publishing + the /gallery page).
# Set all four variables to expose the "Publish to Cloud" button in the world
# builder and to populate /gallery. Leave them unset and the feature is hidden;
# the rest of the app continues to work unchanged.
#
# === Production: Cloudflare R2 ===
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
#
# === Local dev: MinIO via docker-compose ===
# Run `docker compose up -d` at the repo root to start a local S3-compatible
# server on http://localhost:9000 with a preset bucket named "vibe-land-dev".
# Then uncomment the block below (and leave R2_ACCOUNT_ID unset). `vercel dev`
# will auto-load this file.
#
# R2_ENDPOINT=http://localhost:9000
# R2_ACCESS_KEY_ID=minioadmin
# R2_SECRET_ACCESS_KEY=minioadmin
# R2_BUCKET=vibe-land-dev
# R2_REGION=us-east-1
# R2_FORCE_PATH_STYLE=1

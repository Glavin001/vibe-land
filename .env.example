# Rust game server
BIND_ADDR=0.0.0.0:4001
SKIP_SPACETIMEDB_VERIFY=1
SERVER_PORT=4001
SERVER_HOST=localhost

# Optional: point the client at a separate multiplayer backend origin.
# Leave unset when the web app and game server share the same origin.
# VITE_MULTIPLAYER_HTTP_ORIGIN=https://game.example.com

# WebTransport (QUIC/UDP)
WT_BIND_ADDR=0.0.0.0:4002
WT_HOST=127.0.0.1
# Production: uncomment and point to your CA-signed cert files
# WT_CERT_PEM=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# WT_KEY_PEM=/etc/letsencrypt/live/yourdomain.com/privkey.pem

# Vite dev server
ALLOWED_HOSTS=localhost
CLIENT_PORT=5555

# World publishing + /gallery storage (optional — enables the "Publish to
# Cloud" button in the world builder and populates /gallery). Pick ONE of
# the backends below; leave all of the variables unset to hide the feature
# entirely without breaking the rest of the app.
#
# === Backend 1: local filesystem ===
# Simplest option. Store worlds + screenshots under a directory on the same
# machine that runs the Vercel serverless functions (or `vercel dev`). No
# external services required. Takes precedence over the R2 variables when
# both are set.
#
# WORLDS_STORAGE_DIR=/var/lib/vibe-land-worlds
#
# === Backend 2a: Cloudflare R2 (production) ===
# Set all four variables to use real R2.
#
# IMPORTANT: the R2 bucket needs a CORS policy so browser presigned PUTs
# work. In the Cloudflare dashboard go to R2 → your bucket → Settings →
# CORS Policy and add:
#
#   [{"AllowedOrigins":["*"],"AllowedMethods":["GET","PUT","HEAD"],
#     "AllowedHeaders":["*"],"ExposeHeaders":["ETag"],"MaxAgeSeconds":3600}]
#
# Without this the browser will block the presigned uploads with
# "No 'Access-Control-Allow-Origin' header" errors.
#
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
#
# === Backend 2b: local MinIO via docker-compose (R2 emulator) ===
# Run `npm run r2:up` at the repo root to start a local S3-compatible server
# on http://localhost:9000 with a preset bucket named "vibe-land-dev". Then
# uncomment the block below (and leave R2_ACCOUNT_ID unset). `vercel dev`
# will auto-load this file.
#
# R2_ENDPOINT=http://localhost:9000
# R2_ACCESS_KEY_ID=minioadmin
# R2_SECRET_ACCESS_KEY=minioadmin
# R2_BUCKET=vibe-land-dev
# R2_REGION=us-east-1
# R2_FORCE_PATH_STYLE=1

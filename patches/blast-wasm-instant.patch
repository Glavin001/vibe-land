 use std::collections::{HashMap, HashSet};
+
+#[cfg(not(target_arch = "wasm32"))]
 use std::time::Instant;
 
+// `std::time::Instant::now()` panics on `wasm32-unknown-unknown` because the
+// target has no monotonic clock.  The stress-solver uses these instants only
+// to populate telemetry fields (`plan_ms`, `apply_ms`, …).  On wasm we
+// substitute a zero-cost shim whose `elapsed()` always reports
+// `Duration::ZERO` so the telemetry fields stay at `0.0` and no runtime panic
+// ever fires.
+#[cfg(target_arch = "wasm32")]
+#[derive(Clone, Copy)]
+struct Instant;
+
+#[cfg(target_arch = "wasm32")]
+impl Instant {
+    fn now() -> Self {
+        Self
+    }
+    fn elapsed(&self) -> std::time::Duration {
+        std::time::Duration::ZERO
+    }
+}

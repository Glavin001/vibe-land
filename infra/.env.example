# WebTransport infrastructure configuration
# Copy this file to .env and fill in your values, or export as environment variables

# Your domain for the WebTransport server (required)
WT_DOMAIN=wt.yourdomain.com

# Directory containing fullchain.pem and privkey.pem
# Defaults to /etc/letsencrypt/live/$WT_DOMAIN if unset
# WT_CERT_DIR=/etc/letsencrypt/live/wt.yourdomain.com
